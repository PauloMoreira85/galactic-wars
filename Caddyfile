# HTTPS automático (Let's Encrypt) + proxy pro app. Troque o domínio se precisar.
galacticwar.com.br, www.galacticwar.com.br {
	encode gzip

	# Cache: usamos header_down (sobrescreve o Cache-Control do Express; o `header`
	# normal rodava antes do proxy e DUPLICAVA o cabeçalho).
	# /assets/* tem hash no nome -> cache eterno. O resto (index.html, rotas SPA,
	# /art, /api) -> no-cache: sempre revalida, então após um deploy o navegador
	# pega o index novo (e o JS novo) sozinho.
	handle /assets/* {
		reverse_proxy app:3001 {
			header_down Cache-Control "public, max-age=31536000, immutable"
		}
	}
	handle {
		reverse_proxy app:3001 {
			header_down Cache-Control "no-cache"
		}
	}
}

# Fórum do Universo (phpBB) no subdomínio.
forum.galacticwar.com.br {
	reverse_proxy forum:80
	encode gzip
}
