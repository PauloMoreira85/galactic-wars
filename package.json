{
  "name": "galactic-wars",
  "version": "0.1.0",
  "private": true,
  "description": "Galactic Wars - jogo de estrategia espacial tick-based multiplayer",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "db:setup": "npm run db:setup --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
