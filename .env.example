# Copie para .env (dev) ou configure como variáveis de ambiente no host (produção).

# Banco SQLite. Dev: relativo ao server/prisma. Produção: caminho no disco persistente.
DATABASE_URL="file:./dev.db"
# Produção (Render/Railway com disco em /data):
# DATABASE_URL="file:/data/prod.db"

# Segredo do JWT. OBRIGATÓRIO em produção (o server recusa subir com o default).
# Gere um forte, ex.: openssl rand -hex 32
JWT_SECRET="dev-secret-troque-em-producao"

# Intervalo do tick em segundos (3600 = 1h). Use algo pequeno p/ testar.
TICK_INTERVAL_SECONDS="3600"

# Porta. Em dev usamos API_PORT (evita colisão com ferramentas de preview).
# Em produção o host injeta PORT automaticamente.
API_PORT="3001"

# NODE_ENV=production ativa: servir o client buildado + checagem do JWT_SECRET.
# NODE_ENV="production"
